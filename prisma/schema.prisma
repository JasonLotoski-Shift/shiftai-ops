// Shift AI Ops — Prisma schema
// Mirrors lib/types.ts. Keep them in sync when adding/renaming fields.
// IDs default to cuid() for new records; the initial seed passes explicit IDs
// (p-1, c-1, ...) so cross-references in seed.ts remain stable.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Connection URL lives in prisma.config.ts → process.env["DATABASE_URL"]
  // (Prisma 7 moved it out of the schema file.)
}

// ──────────────────────────────────────────────────────────────────────
// Enums (mirror the union types in lib/types.ts; @map preserves the
// hyphenated DB values the existing UI / seed already use)
// ──────────────────────────────────────────────────────────────────────

enum Industry {
  automotive
  motorsport
  engineering
  construction
  other
}

enum InteractionType {
  call
  meeting
  email_sent     @map("email-sent")
  email_received @map("email-received")
  other
}

enum DealStage {
  lead
  qualified
  discovery
  proposal
  negotiation
  signed
}

enum EngagementStatus {
  on_track @map("on-track")
  at_risk  @map("at-risk")
  blocked
  closing
  closed
}

enum ProjectPhase {
  discovery
  build
  run
}

enum MilestoneStatus {
  pending
  in_progress @map("in-progress")
  complete
  at_risk     @map("at-risk")
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
}

enum ActivityType {
  touch
  status
  doc
  ai
}

enum TaskPriority {
  high
  medium
  low
}

enum UpdateCadence {
  daily
  weekly
}

enum ArtifactType {
  proposal
  deck
  email
  sow
  invoice
  report
  other
}

enum ArtifactReviewStatus {
  draft
  approved
  sent
  archived
}

enum AgentPlanStatus {
  idea
  active
  paused
  done
}

// ──────────────────────────────────────────────────────────────────────
// Partner — firm members. Doubles as the actor reference for owner /
// lead fields. NextAuth tables will be added when SSO is wired —
// Partner links via email match at first login.
// ──────────────────────────────────────────────────────────────────────

model Partner {
  id       String @id @default(cuid())
  name     String
  initials String
  role     String
  email    String @unique

  contactsLed     Contact[] @relation("PartnerContactLead")
  dealsLed        Deal[]    @relation("PartnerDealLead")
  clientsLed      Client[]  @relation("PartnerClientLead")
  projectsLed     Project[] @relation("PartnerProjectLead")
  projectsConsult Project[] @relation("ProjectConsultants")
  tasksOwned      Task[]    @relation("TaskOwner")
  tasksAssigned   Task[]    @relation("TaskAssignedBy")
  agentPlans      AgentPlan[] @relation("AgentPlanCreatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────────
// Contact + relationship-intelligence enrichment
// ──────────────────────────────────────────────────────────────────────

model Contact {
  id          String   @id @default(cuid())
  name        String
  title       String
  company     String
  email       String
  phone       String?
  industry    Industry
  source      String
  notes       String?
  lastTouchAt DateTime

  partnerLead   Partner @relation("PartnerContactLead", fields: [partnerLeadId], references: [id])
  partnerLeadId String

  // Enrichment — append-only, never silently overwritten
  persona             String?
  communicationStyle  String?
  keyFacts            String[]
  background          String?
  hobbies             String[]
  networkAffiliations String[]
  enrichedAt          DateTime?

  interactions      Interaction[]
  deals             Deal[]
  primaryForClients Client[]      @relation("ClientPrimaryContact")
  billingForClients Client[]      @relation("ClientBillingContact")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────────
// Interaction — append-only comms log
// ──────────────────────────────────────────────────────────────────────

model Interaction {
  id       String          @id @default(cuid())
  type     InteractionType
  date     DateTime
  summary  String
  // Free-text actor — partner name OR agent label like "AGENT · CLAUDE".
  // Not a Partner FK because agents aren't Partners (yet).
  loggedBy String
  channel  String?

  contact   Contact @relation(fields: [contactId], references: [id])
  contactId String

  createdAt DateTime @default(now())

  @@index([contactId, date])
}

// ──────────────────────────────────────────────────────────────────────
// Deal — pipeline. valueEstimate is whole CAD (matches existing seed).
// ──────────────────────────────────────────────────────────────────────

model Deal {
  id              String    @id @default(cuid())
  company         String
  stage           DealStage
  valueEstimate   Int
  industry        Industry
  closeTargetDate DateTime
  lastTouchAt     DateTime
  // When the deal entered its CURRENT stage — drives the board's aging colors
  // (green < 14d, orange < 28d, red beyond). Reset on every stage move.
  stageEnteredAt  DateTime  @default(now())
  notes           String?

  contact   Contact @relation(fields: [contactId], references: [id])
  contactId String

  partnerLead   Partner @relation("PartnerDealLead", fields: [partnerLeadId], references: [id])
  partnerLeadId String

  artifacts Artifact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────────
// Client — signed engagements. Company-profile + billing sub-fields.
// ──────────────────────────────────────────────────────────────────────

model Client {
  id               String           @id @default(cuid())
  company          String
  industry         Industry
  revenue          String
  driveFolderUrl   String
  workspacePath    String
  contractValue    Int
  contractSignedAt DateTime
  status           EngagementStatus
  notes            String?

  partnerLead   Partner @relation("PartnerClientLead", fields: [partnerLeadId], references: [id])
  partnerLeadId String

  primaryContact   Contact @relation("ClientPrimaryContact", fields: [primaryContactId], references: [id])
  primaryContactId String

  // Company profile — auto-built from comms + web search, append-only
  companySize     String?
  headquarters    String?
  founded         String?
  website         String?
  ownership       String?
  description     String?
  brandColors     String[]
  logoMonogram    String?
  companyKeyFacts String[]
  enrichedAt      DateTime?

  // Engagement / billing
  paymentTerms     String?
  contractEndAt    DateTime?
  billingContact   Contact?  @relation("ClientBillingContact", fields: [billingContactId], references: [id])
  billingContactId String?

  projects  Project[]
  invoices  Invoice[]
  tasks     Task[]
  artifacts Artifact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────────
// Project — per-client engagement
// ──────────────────────────────────────────────────────────────────────

model Project {
  id            String           @id @default(cuid())
  name          String
  phase         ProjectPhase
  status        EngagementStatus
  startDate     DateTime
  targetEndDate DateTime
  budgetFee     Int
  description   String

  client   Client @relation(fields: [clientId], references: [id])
  clientId String

  partnerLead   Partner @relation("PartnerProjectLead", fields: [partnerLeadId], references: [id])
  partnerLeadId String

  consultants Partner[] @relation("ProjectConsultants")

  milestones   Milestone[]
  invoices     Invoice[]
  tasks        Task[]
  artifacts    Artifact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────────
// Milestone
// ──────────────────────────────────────────────────────────────────────

model Milestone {
  id      String          @id @default(cuid())
  title   String
  dueDate DateTime
  status  MilestoneStatus

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────────
// Invoice
// ──────────────────────────────────────────────────────────────────────

model Invoice {
  id       String        @id @default(cuid())
  number   String        @unique
  amount   Int
  issuedAt DateTime
  dueAt    DateTime
  paidAt   DateTime?
  status   InvoiceStatus

  client   Client @relation(fields: [clientId], references: [id])
  clientId String

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────────
// Activity feed — display-only firm activity stream
// ──────────────────────────────────────────────────────────────────────

model Activity {
  id     String       @id @default(cuid())
  ts     DateTime
  actor  String
  type   ActivityType
  target String
  detail String
  // Optional deep-link (relative URL like "/pipeline/<id>") so a feed row
  // clicks through to the record it describes. Free-text, not an FK —
  // matches the loose-coupling convention of the other log models
  // (Interaction.loggedBy, Activity.actor).
  link   String?

  createdAt DateTime @default(now())

  @@index([ts])
}

// ──────────────────────────────────────────────────────────────────────
// Task — dashboard "do" list
// ──────────────────────────────────────────────────────────────────────

model Task {
  id        String       @id @default(cuid())
  title     String
  due       DateTime
  priority  TaskPriority
  relatedTo String?
  done      Boolean      @default(false)
  // Free-text context for the task — manual notes and/or suggested context.
  // No task is a bare button: this is the payload API agents will read (Phase 4+).
  context   String?

  // The owner IS the assignee. assignedBy records who handed it over
  // (null = self-created / firm task). Two relations to Partner, so both
  // must be named.
  owner        Partner  @relation("TaskOwner", fields: [ownerId], references: [id])
  ownerId      String
  assignedBy   Partner? @relation("TaskAssignedBy", fields: [assignedById], references: [id])
  assignedById String?

  // Scoping FKs (nullable — firm-wide tasks have neither).
  // Enables "what's open on Acme" queries without parsing relatedTo.
  client    Client?  @relation(fields: [clientId], references: [id])
  clientId  String?
  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([projectId])
}

// ──────────────────────────────────────────────────────────────────────
// TeamUpdate — dashboard "know" feed
// ──────────────────────────────────────────────────────────────────────

model TeamUpdate {
  id      String        @id @default(cuid())
  ts      DateTime
  author  String
  cadence UpdateCadence
  body    String

  createdAt DateTime @default(now())

  @@index([ts])
}

// ──────────────────────────────────────────────────────────────────────
// NewsItem — industry news for the "know" feed
// ──────────────────────────────────────────────────────────────────────

model NewsItem {
  id       String   @id @default(cuid())
  ts       DateTime
  source   String
  industry Industry
  headline String
  why      String

  createdAt DateTime @default(now())

  @@index([ts])
}

// ──────────────────────────────────────────────────────────────────────
// Artifact — first-class deliverable tracking. Every AI-generated or
// partner-uploaded file gets a row. Powers Deliverables tabs + harvest.
// Persistence recipe in shiftai-ops/CLAUDE.md "Wire a Quick Action".
// ──────────────────────────────────────────────────────────────────────

model Artifact {
  id                 String               @id @default(cuid())
  type               ArtifactType
  title              String
  driveUrl           String
  fileName           String?
  // Free-text actor — partner name OR agent label ("AGENT · CLAUDE").
  createdBy          String
  generatedFromSkill String?
  reviewStatus       ArtifactReviewStatus @default(draft)

  // Scope FKs — exactly one expected at write time, all nullable so
  // a single model serves Client/Project/Deal scopes without a join table.
  client    Client?  @relation(fields: [clientId], references: [id])
  clientId  String?
  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?
  deal      Deal?    @relation(fields: [dealId], references: [id])
  dealId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, createdAt])
  @@index([projectId, createdAt])
  @@index([dealId, createdAt])
}

// ──────────────────────────────────────────────────────────────────────
// AuditLog — every write logged with actor + timestamp.
// Foundation for the AI activity audit acquirers will want (Phase 2C, §11).
// Append-only by convention (no updatedAt; no UI delete path).
// ──────────────────────────────────────────────────────────────────────

// ──────────────────────────────────────────────────────────────────────
// AgentPlan — Firm Agents tab (B5). A collaboration surface, NOT a deploy:
// partners draft what an agent SHOULD do (goal + key tasks) before any
// SKILL.md / scheduled run exists. Simple CRUD. The "live agents" half of
// the tab reads the actual SKILL.md files off disk (no model needed).
// ──────────────────────────────────────────────────────────────────────

model AgentPlan {
  id        String          @id @default(cuid())
  name      String
  goal      String
  keyTasks  String[]
  notes     String?
  status    AgentPlanStatus @default(idea)

  createdBy   Partner @relation("AgentPlanCreatedBy", fields: [createdById], references: [id])
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model AuditLog {
  id         String   @id @default(cuid())
  ts         DateTime @default(now())
  actor      String   // partner.id or "agent:<name>"
  actorLabel String
  action     String   // e.g. "create.contact", "update.deal.stage"
  targetType String   // e.g. "Contact", "Deal"
  targetId   String?
  changes    Json?    // before/after diff
  ip         String?
  userAgent  String?

  @@index([ts])
  @@index([targetType, targetId])
}

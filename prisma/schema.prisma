// Shift AI Ops — Prisma schema
// Mirrors lib/types.ts. Keep them in sync when adding/renaming fields.
// IDs default to cuid() for new records; the initial seed passes explicit IDs
// (p-1, c-1, ...) so cross-references in seed.ts remain stable.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Connection URL lives in prisma.config.ts → process.env["DATABASE_URL"]
  // (Prisma 7 moved it out of the schema file.)
}

// ──────────────────────────────────────────────────────────────────────
// Enums (mirror the union types in lib/types.ts; @map preserves the
// hyphenated DB values the existing UI / seed already use)
// ──────────────────────────────────────────────────────────────────────

enum Industry {
  automotive
  motorsport
  engineering
  construction
  architecture
  real_estate
  manufacturing
  heavy_equipment
  distribution
  logistics
  professional_services
  healthcare
  beverage
  other
}

enum InteractionType {
  call
  meeting
  email_sent     @map("email-sent")
  email_received @map("email-received")
  other
}

enum DealStage {
  lead
  qualified
  discovery
  discussion
  proposal
  negotiation
  signed
}

// Where a lead/contact came from — a structured bucket used to color-code
// lead cards on the pipeline board. The free-text Contact.source stays as the
// human "where exactly" note; this is the closed set for coloring + filtering.
enum LeadSource {
  intro
  outbound
  referral
  event
  inbound
  ai_found // surfaced by the discovery agent (AI Found Leads)
  imported // promoted from a partner's imported contacts
  other
}

// Lead Agent — Phase B: AI Found Leads (the review surface for discovered prospects).
// 'contacted' (Phase B.1) sits between pending and added: a cold-outreach email
// has been sent and we're waiting on a reply. Enum sort order is cosmetic —
// the app keys off string equality, never ordinal.
enum ProspectLeadStatus {
  pending
  contacted
  added
  ghost
}

enum LeadRunStatus {
  running
  done
  error
}

enum EngagementStatus {
  on_track @map("on-track")
  at_risk  @map("at-risk")
  blocked
  closing
  closed
}

enum ProjectPhase {
  discovery
  build
  run
}

enum MilestoneStatus {
  pending
  in_progress @map("in-progress")
  complete
  at_risk     @map("at-risk")
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
}

enum ActivityType {
  touch
  status
  doc
  ai
}

enum TaskPriority {
  high
  medium
  low
}

enum UpdateCadence {
  daily
  weekly
}

enum ArtifactType {
  proposal
  deck
  email
  sow
  contract
  invoice
  report
  other
}

enum ArtifactReviewStatus {
  draft
  approved
  sent
  archived
}

// Firm Knowledge — who may pull an item into an AI skill's context. firm_wide
// is the default; managing_partner items (firm economics) are filtered out at
// retrieval time before any chunk reaches a non-managing-partner session.
enum KnowledgeSensitivity {
  firm_wide
  managing_partner
}

// Firm Knowledge — how much a skill should trust an item when answering.
enum KnowledgeConfidence {
  high
  medium
  low
}

// Firm Knowledge — the fixed set of recent-memory blocks (Tier-1, always in
// context). One row per key; the set is curated, not user-extensible.
enum MemoryBlockKey {
  firm_state
  active_engagements
  recent_decisions
  watch_list
}

// Firm Knowledge — where a Tier-2 KnowledgeItem came from. Drives provenance
// display + which parse path runs (uploaded/captured = a stored blob to parse;
// transcript/agent/manual = text arrives inline).
enum KnowledgeSource {
  uploaded
  captured
  transcript
  agent
  manual
}

// Firm Knowledge — async parse lifecycle for an uploaded KnowledgeItem. The
// upload broker creates the row at `pending`; the knowledge-parse cron flips it
// to `parsed` (text + hash written), `empty` (no extractable text), or `failed`.
// Inline-text sources (manual/transcript) are created already `parsed`.
enum KnowledgeParseStatus {
  pending
  parsed
  empty
  failed
}

enum AgentPlanStatus {
  idea
  active
  paused
  done
}

// A plan row is either an agent plan or an MCP plan — same shape, same CRUD,
// rendered under different tabs on the Agents & MCPs page.
enum AgentPlanKind {
  agent
  mcp
}

enum ChannelKind {
  channel
  dm
  system
}

// Typed system notifications — drives the color + icon in the per-partner
// "Claude" system chat. 'chat' is an ordinary human message (the default for
// DMs/channels); the rest are AI/system notes.
enum MessageKind {
  chat
  task_assigned     @map("task-assigned")
  deliverable_added @map("deliverable-added")
  approval_needed   @map("approval-needed")
  ops_alert         @map("ops-alert")
}

enum IngestSource {
  paste
  fireflies
  drop
  gmail
}

enum InstallmentTrigger {
  on_signing @map("on-signing")
  milestone
  date
  manual
}

enum InstallmentStatus {
  planned
  invoiced
  paid
}

// How a project's standard client billing schedule is generated.
//   fifty_twenty_five — 50% on signing / 25% mid / 25% delivery (pilots/projects, default)
//   monthly_even      — total value split evenly across the contract months (retainers)
//   custom            — partner-built schedule; the generator leaves it alone
enum ScheduleType {
  fifty_twenty_five @map("fifty-twenty-five")
  monthly_even      @map("monthly-even")
  custom
}

// Estimate lifecycle (pre-proposal scoping). A sent estimate that's edited is
// superseded by a new version; an accepted estimate converts to project economics.
enum EstimateStatus {
  draft
  sent
  accepted
  superseded
}

// Consultant payout lifecycle: owed → paid (e-transfer/wire sent) → confirmed
// (consultant acknowledged receipt).
enum PayoutStatus {
  owed
  paid
  confirmed
}

enum PayoutMethod {
  etransfer @map("e-transfer")
  wire
  cheque
  other
}

enum IngestStatus {
  pending
  approved
  rejected
}

// Project type — the kind of engagement (replaces the discovery/build/run
// `phase` in the UI; phase column is retained for back-compat). Business
// model v2: `monthly_project` was renamed in place to `subscription` (the core
// recurring engagement) and `buyout` was added (the premium buy-out). One
// engagement = one project: a later subscription or buy-out is a NEW project.
enum ProjectType {
  discovery_report @map("discovery-report")
  pilot_project    @map("pilot-project")
  subscription
  full_build       @map("full-build")
  buyout
}

// Deal-source commission base — what the 1-10% applies to. @map'd hyphenated DB
// value per the enum-string convention (gotcha #5): JS sees the underscored id.
enum CommissionBase {
  deal_value @map("deal-value")
  total_6mo  @map("total-6mo")
  total_12mo @map("total-12mo")
}

// Lifecycle of an on-going service contract (the recurring subscription that
// begins after the build completes — so it opens at `pending_start`).
enum ServiceContractStatus {
  pending_start @map("pending-start")
  active
  ended
  cancelled
}

// One month's recurring commission accrual: projected (future), accrued (its
// month has started), or paid.
enum CommissionAccrualStatus {
  projected
  accrued
  paid
}

// Work category — colours/tags a milestone or task on the board. Defaults from
// what it's tied to (project → project, deal → pipeline, else firm/other) and
// is editable. Firm items can carry a free sub-label (BD, Admin).
enum WorkCategory {
  firm
  project
  pipeline
  other
}

// Task board status — the Kanban columns. `done` boolean is kept in sync
// (done === status "done") so existing dashboard widgets keep working.
enum TaskStatus {
  todo
  in_progress @map("in-progress")
  in_review   @map("in-review")
  done
}

// ──────────────────────────────────────────────────────────────────────
// Import Contacts (Phase: CSV import → scan → promote). These enums are
// BRAND-NEW (no legacy data), so values are plain underscored identifiers
// with NO @map — Prisma returns exactly what's stored and lib/types.ts
// mirrors them verbatim (no hyphen/underscore conversion, sidesteps the
// EngagementStatus-style mapping gotcha). Display labels live in the UI.
// ──────────────────────────────────────────────────────────────────────

// Did an imported row carry enough to judge fit (company + title), or is it
// effectively a name-only row that must be identified before it can be scored?
enum ImportContactCompleteness {
  complete
  needs_identification
}

// The scan's person-role verdict: a decision-maker we can sell to directly, a
// senior/management CONNECTOR who can intro us to a decision-maker at a fitting
// company, or neither.
enum ImportLeadType {
  decision_maker
  connector
  none
}

// Per-row scan lifecycle. `skipped` = a needs_identification row the scan did
// not rate (no AI/credit spend); `error` = the batch request for this row failed.
enum ImportScanStatus {
  pending
  scored
  skipped
  error
}

// A scan pass lifecycle. `submitted` = an Anthropic Message Batch is in flight;
// `scoring` = results are being written back (the idempotency guard state).
enum ScanRunStatus {
  pending
  submitted
  scoring
  done
  error
}

// Has an imported contact been pushed into a firm-wide ProspectLead yet?
enum ImportContactPromotion {
  none
  promoted
}

// Where a ProspectLead came from. `discovery` = surfaced by runDiscovery (the
// existing AI Found Leads behavior); `imported` = promoted from a partner's
// imported contacts (the new Pipeline "Promoted Leads" sub-tab). Default keeps
// every existing row as `discovery` on migrate.
enum ProspectLeadOrigin {
  discovery
  imported
}

// Contact ↔ Deal/Client link dimensions (D40 records upgrade).
// `relationship` = how the person connects to the company; `role` = their
// pull in the buying decision (meaningful mainly for works_there). Brand-new
// enums → plain underscored values, no @map (Import-Contacts precedent).

enum RelationshipType {
  works_there
  introduced_us
  advisor
  other
}

enum StakeholderRole {
  decision_maker
  champion
  influencer
  budget_holder
  technical
  gatekeeper
  blocker
  other
}

enum PreferredChannel {
  email
  call
  text
  linkedin
}

enum RelationshipStrength {
  cold
  warm
  strong
}

// ──────────────────────────────────────────────────────────────────────
// Feature Requests & Fixes — the in-tool feedback board. Any partner files
// an item AND can move its status (firm decision: lightweight, everyone owns
// the board — no managing-partner gate). Brand-new enums → plain underscored
// values, NO @map (Import-Contacts precedent; lib/types.ts mirrors verbatim).
// ──────────────────────────────────────────────────────────────────────

enum FeatureRequestType {
  bug // "Bug fix"
  feature // "New feature"
  improvement
  broken // broken / blocking
}

enum FeatureRequestStatus {
  open
  in_progress
  done
  declined // won't do / not now
}

// ──────────────────────────────────────────────────────────────────────
// Partner — firm members. Doubles as the actor reference for owner /
// lead fields. NextAuth tables will be added when SSO is wired —
// Partner links via email match at first login.
// ──────────────────────────────────────────────────────────────────────

model Partner {
  id       String @id @default(cuid())
  name     String
  initials String
  role     String
  email    String @unique

  contactsLed        Contact[]       @relation("PartnerContactLead")
  dealsLed           Deal[]          @relation("PartnerDealLead")
  clientsLed         Client[]        @relation("PartnerClientLead")
  projectsLed        Project[]       @relation("PartnerProjectLead")
  projectsConsult    Project[]       @relation("ProjectConsultants")
  tasksOwned         Task[]          @relation("TaskOwner")
  tasksAssigned      Task[]          @relation("TaskAssignedBy")
  reviewTasks        Task[]          @relation("TaskReviewer")
  milestonesOwned    Milestone[]     @relation("MilestoneOwner")
  agentPlans         AgentPlan[]     @relation("AgentPlanCreatedBy")
  channelMemberships ChannelMember[]
  messagesAuthored   Message[]
  originations       Origination[]
  dealCommissions     DealSourceCommission[]      @relation("PartnerDealCommission")
  projectCommissions  ProjectSourceCommission[]   @relation("PartnerProjectCommission")
  ongoingCommissions  OngoingContractCommission[] @relation("PartnerOngoingCommission")
  serviceContractsLed ServiceContract[]           @relation("PartnerServiceContractLead")

  // Reimbursable expenses this partner fronted (firm financials · AP/AR).
  expensesPaid        Expense[]

  // Team notes left on architecture-map cards (the /architecture tab).
  architectureNotes  ArchitectureNote[]

  // Gmail ingest — per-partner OAuth connection + incremental poll cursors.
  gmailAuth        PartnerGmailAuth?
  ingestSyncStates IngestSyncState[]

  // Import Contacts — a partner's PRIVATE imported network + scan passes.
  importBatches    ImportBatch[]     @relation("PartnerImportBatch")
  importedContacts ImportedContact[] @relation("PartnerImportedContact")
  scanRuns         ScanRun[]         @relation("PartnerScanRun")

  // Optional link to a Consultant roster entry — a partner who is ALSO paid as
  // a consultant on projects (rare). Externals (sub-consultants) have no Partner.
  consultantProfile Consultant? @relation("PartnerConsultant")

  // Last time this partner opened What's new — drives the unread dot + bolding.
  whatsNewSeenAt DateTime?

  // Feature Requests & Fixes filed by this partner (the in-tool feedback board).
  featureRequests FeatureRequest[] @relation("FeatureRequestsCreated")

  // Firm Knowledge — categories this partner stewards + artifacts they own.
  knowledgeCategoriesOwned KnowledgeCategory[] @relation("KnowledgeCategorySteward")
  artifactsOwned           Artifact[]          @relation("ArtifactOwner")
  memoryBlocksApproved     MemoryBlock[]       @relation("MemoryBlockApprover")

  // Firm Knowledge — Tier-2 records this partner owns / decided / stewards (Phase 3).
  knowledgeItemsOwned KnowledgeItem[]  @relation("KnowledgeItemOwner")
  decisionsRecorded   DecisionRecord[] @relation("DecisionDecidedBy")
  knowledgeTagsOwned  KnowledgeTag[]   @relation("KnowledgeTagSteward")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────────
// Contact + relationship-intelligence enrichment
// ──────────────────────────────────────────────────────────────────────

model Contact {
  id             String      @id @default(cuid())
  name           String
  title          String
  company        String
  email          String
  phone          String?
  industry       Industry
  subIndustry    String? // finer than Industry — "heavy-civil", "motorsport fab"
  source         String // free-text "where exactly" note
  sourceCategory LeadSource? // structured bucket — color-codes lead cards
  // Normalized bare domain (lowercase, no scheme/www) — powers the
  // "already in pipeline" dedup against discovered ProspectLeads (D15). NOT unique.
  domain         String?
  notes          String?
  lastTouchAt    DateTime

  partnerLead   Partner @relation("PartnerContactLead", fields: [partnerLeadId], references: [id])
  partnerLeadId String

  // Enrichment — append-only, never silently overwritten
  persona             String?
  communicationStyle  String?
  keyFacts            String[]
  background          String?
  hobbies             String[]
  networkAffiliations String[]
  enrichedAt          DateTime?

  // Reach & personal (D40 records upgrade) — all optional.
  // relationshipStrength is partner judgment: manual UI only, never AI-proposed.
  linkedinUrl          String?
  location             String? // city/region, free text
  timezone             String? // e.g. "America/Vancouver" or "PT" — scheduling aid
  mobilePhone          String? // separate from main phone
  preferredChannel     PreferredChannel?
  relationshipStrength RelationshipStrength?
  importantDates       String[] // free text, e.g. "Birthday — March 12"

  interactions      Interaction[]
  deals             Deal[]
  primaryForClients Client[]      @relation("ClientPrimaryContact")
  billingForClients Client[]      @relation("ClientBillingContact")
  links             ContactLink[]
  // The person's company hats — one row per {company, role}. The isPrimary row
  // mirrors the scalar `company`/`title` above (the synced source of truth all
  // legacy reads use); the others are additional affiliations (e.g. CEO of two
  // companies). Managed via lib/contact-affiliations.ts. Distinct from `links`,
  // which is the buying relationship to a specific Deal/Client.
  affiliations      ContactAffiliation[]
  clientLeadProjects Project[]    @relation("ProjectClientLead")
  tasks             Task[]
  actionDrafts      ActionDraft[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────────
// ContactAffiliation — a contact's company hats. One row per {company,
// role}; exactly one isPrimary row, whose company/title mirror the scalar
// Contact.company/title (kept in sync by lib/contact-affiliations.ts so the
// 300+ existing reads of the scalar keep working). This models employment /
// the person's roles, NOT a buying relationship to a Deal/Client (that's
// ContactLink). Brand-new model → plain underscored fields, no @map.
// ──────────────────────────────────────────────────────────────────────

model ContactAffiliation {
  id        String  @id @default(cuid())
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  company   String
  title     String? // their role at this company — "CEO", "VP Ops"
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
}

// ──────────────────────────────────────────────────────────────────────
// Interaction — append-only comms log
// ──────────────────────────────────────────────────────────────────────

model Interaction {
  id       String          @id @default(cuid())
  type     InteractionType
  date     DateTime
  summary  String
  // Full original text (email/meeting body). Source of truth for "show me the
  // thread"; `summary` stays the collapsed one-liner. Nullable — legacy rows + a
  // manual log have no body.
  body     String?
  // Email subject + the source message/meeting id (dedup; NON-unique — app-level
  // dedup, see lib/ingest). threadId groups a Gmail thread's messages so a client
  // page can show one growing conversation and the poll can detect "already filed".
  subject    String?
  externalId String?
  threadId   String?
  // Free-text actor — partner name OR agent label like "AGENT · CLAUDE".
  // Not a Partner FK because agents aren't Partners (yet).
  loggedBy String
  channel  String?

  // Comms is now scoped to whichever of contact / client / deal apply. contactId
  // is NULLABLE: auto-ingested mail that matched no contact still lands, scoped by
  // client/deal (the polymorphic-scope convention used by Task / ContactLink).
  contact   Contact? @relation(fields: [contactId], references: [id])
  contactId String?
  client    Client?  @relation(fields: [clientId], references: [id])
  clientId  String?
  deal      Deal?    @relation(fields: [dealId], references: [id])
  dealId    String?

  // Decisions distilled from this interaction (e.g. a meeting transcript →
  // DecisionRecord). Back-relation for DecisionRecord.sourceInteraction.
  decisionsSourced DecisionRecord[] @relation("DecisionSourceInteraction")

  createdAt DateTime @default(now())

  @@index([contactId, date])
  @@index([clientId, date])
  @@index([dealId, date])
  @@index([threadId])
  @@index([externalId])
}

// ──────────────────────────────────────────────────────────────────────
// ContactLink — many-to-many Contact ↔ Deal/Client (D40). The company side
// is polymorphic: exactly ONE of dealId/clientId is set (enforced in
// lib/contact-links.ts, the single write path — mirrors Task's scope FKs).
// On Convert, a deal's links re-point dealId → clientId so the buying
// committee + intro path carry into the new client.
// ──────────────────────────────────────────────────────────────────────

model ContactLink {
  id        String  @id @default(cuid())
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  deal      Deal?   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId    String?
  client    Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String?

  relationship RelationshipType @default(works_there)
  role         StakeholderRole? // buying influence — mainly for works_there people
  roleLabel    String? // free text — "VP Ops", "met at SEMA"
  isPrimary    Boolean          @default(false)
  notes        String?
  // Free-text actor — partner name OR "AGENT · CLAUDE" (matches Interaction.loggedBy)
  addedBy      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contactId, dealId])
  @@unique([contactId, clientId])
  @@index([dealId])
  @@index([clientId])
  @@index([contactId])
}

// ──────────────────────────────────────────────────────────────────────
// Deal — pipeline. valueEstimate is whole CAD (matches existing seed).
// ──────────────────────────────────────────────────────────────────────

model Deal {
  id                String    @id @default(cuid())
  // Custom deal name (optional). When set it's the deal's heading; when null the
  // UI falls back to `company` (the historical "auto-assigned" label). One
  // fallback point: dealLabel() in lib/format.ts. `company` is the deal's own
  // company string (defaults from the contact on create, but independent).
  name              String?
  company           String
  stage             DealStage
  valueEstimate     Int
  industry          Industry
  closeTargetDate   DateTime
  lastTouchAt       DateTime
  // When the deal entered its CURRENT stage — drives the board's aging colors
  // (green < 14d, orange < 28d, red beyond). Reset on every stage move.
  stageEnteredAt    DateTime  @default(now())
  // Cold-outreach funnel (D36): set when a lead enters via a sent cold email;
  // outreachRepliedAt stamped when the partner marks the prospect as replied
  // (lead → qualified). Both null for normal Add-to-funnel conversions.
  coldOutreachAt    DateTime?
  outreachRepliedAt DateTime?
  notes             String?

  // Pipeline working-files folder in Drive — created lazily under the shared
  // "00-Pipeline" folder on the first doc save for this deal; moved into the
  // client's folder on convert. Null until a doc is filed.
  driveFolderId  String?
  driveFolderUrl String?

  // Company profile (D40) — gathered at deal stage, mirrors Client's block,
  // copied forward to the new Client on Convert. Append-only via enrich.
  website         String?
  domain          String? // normalized bare host (normalizeDomain). NOT unique.
  linkedinUrl     String?
  instagramUrl    String?
  revenueEstimate Int? // whole CAD — filterable against the $25–200M ICP
  employeeCount   Int?
  companySize     String?
  headquarters    String?
  founded         String?
  ownership       String?
  description     String?
  subIndustry     String? // finer than Industry — "heavy-civil", "motorsport fab"
  currentSystems  String[] // what they run today — the build signal
  painPoints      String[] // where it hurts — the build signal
  companyKeyFacts String[]
  enrichedAt      DateTime?

  // Sales intelligence (D40). probability is partner judgment — manual only.
  nextStep    String?
  competitor  String?
  probability Int? // 0–100, weighted-pipeline input
  budget      String? // as stated/floated — free text, soft until contracted
  lostReason  String?
  lostAt      DateTime?

  contact   Contact @relation(fields: [contactId], references: [id])
  contactId String

  partnerLead   Partner @relation("PartnerDealLead", fields: [partnerLeadId], references: [id])
  partnerLeadId String

  artifacts  Artifact[]
  interactions Interaction[]
  knowledgeItems KnowledgeItem[]
  estimates  Estimate[]
  discoverySurveys DiscoverySurvey[]
  contactLinks ContactLink[]
  tasks      Task[]
  actionDrafts ActionDraft[]
  prototypeRuns PrototypeRun[]
  sourceCommissions DealSourceCommission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Discovery questionnaire (Tally). Generated per-prospect after a discovery call,
// created as a Tally form via API, the link sent in the follow-up email. The
// client's submission lands via webhook and feeds the discovery report. Anchored
// on the Deal; on conversion the same row is repointed to the Client (both FKs
// nullable, like Artifact). See lib/tally.ts + app/api/ingest/tally.
enum DiscoverySurveyStatus {
  draft
  sent
  responded
}

model DiscoverySurvey {
  id        String                @id @default(cuid())
  status    DiscoverySurveyStatus @default(draft)
  title     String
  questions Json // [{ type, label, options?, required?, section? }] — the generated questionnaire

  tallyFormId  String? @unique // webhook join key
  tallyFormUrl String?

  answers              Json? // normalized [{ label, type, value }] from the submission
  respondentName       String?
  respondentEmail      String?
  submittedAt          DateTime?
  driveUrl             String?
  externalSubmissionId String? @unique // Tally responseId — idempotency

  dealId   String? // set at deal stage; retained for provenance after conversion
  clientId String? // added when the deal converts to a client
  deal     Deal?   @relation(fields: [dealId], references: [id])
  client   Client? @relation(fields: [clientId], references: [id])

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId, createdAt])
  @@index([clientId, createdAt])
  @@index([status])
}

// ──────────────────────────────────────────────────────────────────────
// Client — signed engagements. Company-profile + billing sub-fields.
// ──────────────────────────────────────────────────────────────────────

model Client {
  id               String           @id @default(cuid())
  company          String
  industry         Industry
  revenue          String
  driveFolderUrl   String
  workspacePath    String
  contractValue    Int
  contractSignedAt DateTime
  status           EngagementStatus
  notes            String?

  partnerLead   Partner @relation("PartnerClientLead", fields: [partnerLeadId], references: [id])
  partnerLeadId String

  primaryContact   Contact @relation("ClientPrimaryContact", fields: [primaryContactId], references: [id])
  primaryContactId String

  // Company profile — auto-built from comms + web search, append-only
  companySize     String?
  headquarters    String?
  founded         String?
  website         String?
  ownership       String?
  description     String?
  brandColors     String[]
  logoMonogram    String?
  companyKeyFacts String[]
  enrichedAt      DateTime?

  // Presence & firmographics (D40)
  linkedinUrl     String?
  instagramUrl    String?
  domain          String? // normalized bare host (normalizeDomain). NOT unique.
  revenueEstimate Int? // whole CAD — filterable, alongside free-text `revenue`
  employeeCount   Int?
  subIndustry     String?
  locations       String? // sites/regions, free text

  // Shift-specific signal (D40) — what they run, where it hurts, who they sell to
  currentSystems String[]
  painPoints     String[]
  keyServices    String[]
  competitors    String[]

  // Engagement / billing
  statusNote       String? // partner's health note — manual only, never AI-proposed
  renewalDate      DateTime?
  paymentTerms     String?
  contractEndAt    DateTime?
  billingContact   Contact?  @relation("ClientBillingContact", fields: [billingContactId], references: [id])
  billingContactId String?

  projects   Project[]
  invoices   Invoice[]
  tasks      Task[]
  artifacts  Artifact[]
  interactions Interaction[]
  knowledgeItems KnowledgeItem[]
  milestones Milestone[]
  discoverySurveys DiscoverySurvey[]
  contactLinks ContactLink[]
  actionDrafts ActionDraft[]
  prototypeRuns PrototypeRun[]
  serviceContracts ServiceContract[]
  bills      Bill[]
  expenses   Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────────
// Project — per-client engagement
// ──────────────────────────────────────────────────────────────────────

model Project {
  id            String           @id @default(cuid())
  name          String
  phase         ProjectPhase
  // Engagement type — shown in the UI in place of `phase` (which is retained
  // for back-compat). Nullable so existing rows need no backfill.
  projectType   ProjectType?
  status        EngagementStatus
  startDate     DateTime
  targetEndDate DateTime
  budgetFee     Int
  description   String

  client   Client @relation(fields: [clientId], references: [id])
  clientId String

  partnerLead   Partner @relation("PartnerProjectLead", fields: [partnerLeadId], references: [id])
  partnerLeadId String

  // Client-side lead for this project (D40) — who on their side owns it
  clientLead   Contact? @relation("ProjectClientLead", fields: [clientLeadId], references: [id])
  clientLeadId String?

  // Scope & outcomes (D40) — how we prove value, what we're delivering
  objectives     String?
  successMetrics String[]
  systemsBuilt   String[]
  risks          String[]
  statusNote     String?

  consultants Partner[] @relation("ProjectConsultants")

  milestones     Milestone[]
  invoices       Invoice[]
  tasks          Task[]
  artifacts      Artifact[]
  knowledgeItems KnowledgeItem[]
  installments   BillingInstallment[]
  economicsLines ProjectEconomicsLine[]
  directCosts    ProjectDirectCost[]
  payouts        ConsultantPayout[]
  originations   Origination[]
  actionDrafts   ActionDraft[]
  sourceCommissions ProjectSourceCommission[]
  serviceContract   ServiceContract?
  bills             Bill[]
  expenses          Expense[]

  // How the standard client billing schedule is generated (Phase 4):
  // fifty_twenty_five (default, pilots/projects) or monthly_even (retainers).
  scheduleType ScheduleType @default(fifty_twenty_five)

  // Commission/origination (Phase 2). originationPct is the % of LABOUR
  // revenue paid to whoever sourced the contract — first contract per client
  // only. isFirstContract snapshots eligibility at signing (no retroactive
  // renegotiation); when false the origination slot rolls into the firm pool.
  originationPct  Decimal @default(10.00) @db.Decimal(5, 2)
  isFirstContract Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────────
// BillingInstallment — the project's invoicing structure. Each row is one
// planned slice of the contract fee (label + amount + trigger). The
// "Send invoice" button reads these as presets; on bill it links to the
// Invoice it produced and flips status planned → invoiced. Lives on Project
// (not Client) to match Invoice's project FK.
// ──────────────────────────────────────────────────────────────────────

model BillingInstallment {
  id        String             @id @default(cuid())
  label     String
  amount    Int
  trigger   InstallmentTrigger @default(manual)
  dueDate   DateTime?
  sortOrder Int                @default(0)
  status    InstallmentStatus  @default(planned)
  // Out-of-scope billing line (change order / add-on). Summed as "Extras";
  // does not count against "Remaining to be billed".
  isExtra   Boolean            @default(false)

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  // Once billed, the invoice this installment produced (1:1).
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
  invoiceId String?  @unique

  // Consultant payouts owed for this stage.
  payouts ConsultantPayout[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, sortOrder])
}

// ──────────────────────────────────────────────────────────────────────
// Consultant — the firm's pay roster / rate card. A person we PAY on a
// project (team member or external sub-consultant). NOT a login (that's
// Partner). `defaultPayRateCents` is what we pay them per hour (cost); it's
// usually fixed per person and seeds each project economics line, which can
// then be overridden. A Partner who is also paid as a consultant links via
// `partnerId` (optional 1:1). Soft-deleted via `active=false`.
// economicsLines / payouts back-relations are added with their models
// (Phase 2 / Phase 3 migrations).
// ──────────────────────────────────────────────────────────────────────

model Consultant {
  id                  String  @id @default(cuid())
  name                String
  role                String
  // What we pay them per hour, in CENTS (e.g. $150/hr = 15000). Rates are
  // cents (not whole-CAD) for sub-dollar precision; line totals round to CAD.
  defaultPayRateCents Int     @default(0)
  email               String? // for the e-transfer; NOT unique (loose-coupling)
  active              Boolean @default(true)
  notes               String?

  partner   Partner? @relation("PartnerConsultant", fields: [partnerId], references: [id])
  partnerId String?  @unique

  economicsLines ProjectEconomicsLine[]
  payouts        ConsultantPayout[]
  // Reimbursable expenses this person (a non-partner employee/contractor) fronted.
  reimbursedExpenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

// ──────────────────────────────────────────────────────────────────────
// ProjectEconomicsLine — the per-project firm economics breakdown. One row
// per person/role working the project: their estimated hours, what we PAY
// them (payRateCents = cost) and what we BILL the client (billRateCents).
// Σ(hours × billRateCents) of non-extra lines should ≈ the project value;
// Σ(hours × payRateCents) is the firm's cost (what's owed out). `role` is a
// snapshot (the consultant's role may drift). `fromFirmDefault` flags a line
// seeded from the roster vs. overridden by a partner. Rates are CENTS.
// payouts back-relation lands with ConsultantPayout (Phase 3 migration).
// ──────────────────────────────────────────────────────────────────────

model ProjectEconomicsLine {
  id              String  @id @default(cuid())
  role            String
  hours           Decimal @db.Decimal(7, 2)
  payRateCents    Int
  billRateCents   Int
  isExtra         Boolean @default(false)
  sortOrder       Int     @default(0)
  fromFirmDefault Boolean @default(true)
  notes           String?

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  consultant   Consultant? @relation(fields: [consultantId], references: [id])
  consultantId String?

  // The firm rate tier this line was seeded from (Phase 1). Rates are still
  // snapshotted on the line above and overridable; this records the source.
  rateTier   RateTier? @relation(fields: [rateTierId], references: [id])
  rateTierId String?

  payouts ConsultantPayout[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, sortOrder])
  @@index([consultantId])
}

// ──────────────────────────────────────────────────────────────────────
// ConsultantPayout — the money-OUT ledger (parallel to Invoice). One row per
// consultant per client STAGE (BillingInstallment): what they're owed for that
// stage, and whether we've paid them. `amount` auto-defaults to (stage share ×
// the consultant's project cost) and is editable to the actual e-transferred
// amount. `clientPaidFirst` snapshots, at pay time, whether the client invoice
// for that stage was already paid — so we can see if we fronted money.
// ──────────────────────────────────────────────────────────────────────

model ConsultantPayout {
  id              String        @id @default(cuid())
  amount          Int
  status          PayoutStatus  @default(owed)
  method          PayoutMethod?
  paidAt          DateTime?
  confirmedAt     DateTime?
  clientPaidFirst Boolean?
  notes           String?

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  consultant   Consultant @relation(fields: [consultantId], references: [id])
  consultantId String

  // The client stage this payout maps to (the installment IS the stage).
  installment   BillingInstallment @relation(fields: [installmentId], references: [id])
  installmentId String

  economicsLine   ProjectEconomicsLine? @relation(fields: [economicsLineId], references: [id])
  economicsLineId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([installmentId, consultantId])
  @@index([projectId, status])
  @@index([consultantId, status])
}

// ──────────────────────────────────────────────────────────────────────
// Milestone
// ──────────────────────────────────────────────────────────────────────

model Milestone {
  id          String          @id @default(cuid())
  title       String
  // Nullable: a milestone may be undated (then it doesn't appear on the timeline).
  dueDate     DateTime?
  status      MilestoneStatus
  // Board column (To Do / In Progress / In Review / Done). The milestone CARD
  // moves through the funnel on the Task Board; `status` above stays for the
  // timeline and is synced from this on the board.
  boardStatus TaskStatus      @default(todo)
  // When set, the milestone has been moved to the board's Archive column. The
  // timestamp drives the 7-day auto-hide: the Task Board query omits milestones
  // archived more than 7 days ago (they stay in the DB, just off the board).
  // Moving an archived milestone back into a real column clears this.
  archivedAt  DateTime?

  // Universal parent: a milestone may be tied to a project, a client, or
  // nothing (firm-level BD/Admin). All scope FKs are nullable.
  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?
  client    Client?  @relation(fields: [clientId], references: [id])
  clientId  String?

  // Assigned partner (the milestone owner).
  owner   Partner? @relation("MilestoneOwner", fields: [ownerId], references: [id])
  ownerId String?

  // Board categorisation — colour/tag. Defaults from scope; editable.
  category      WorkCategory @default(other)
  categoryLabel String? // free sub-tag for firm work (e.g. "BD", "Admin")

  // Sub-tasks under this milestone (epic → tasks).
  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([ownerId])
}

// ──────────────────────────────────────────────────────────────────────
// Invoice
// ──────────────────────────────────────────────────────────────────────

model Invoice {
  id       String        @id @default(cuid())
  number   String        @unique
  // `amount` is the subtotal (pre-GST) in whole CAD — kept as the canonical
  // figure all existing AR math reads. gstBps/total are additive (Phase 4):
  // the firm is not GST-registered yet so gstBps defaults to 0 and total ==
  // amount; flip gstBps to 500 (5%) when the firm registers and totals recompute.
  amount   Int
  gstBps   Int           @default(0)
  total    Int           @default(0)
  // Marked manually sent outside the tool (no generated Artifact) — Phase 4.
  isManual Boolean       @default(false)
  issuedAt DateTime
  dueAt    DateTime
  paidAt   DateTime?
  // When the invoice was marked sent. Back-datable: a partner can record the
  // real send date (e.g. an invoice emailed last Tuesday, logged today). Null
  // while a draft; set on the draft→sent transition. Distinct from issuedAt
  // (the row's creation date) — the two usually match but need not.
  sentAt   DateTime?
  status   InvoiceStatus

  client   Client @relation(fields: [clientId], references: [id])
  clientId String

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  // The billing installment this invoice was generated from (if any).
  installment BillingInstallment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────────
// Activity feed — display-only firm activity stream
// ──────────────────────────────────────────────────────────────────────

model Activity {
  id     String       @id @default(cuid())
  ts     DateTime
  actor  String
  type   ActivityType
  target String
  detail String
  // Optional deep-link (relative URL like "/pipeline/<id>") so a feed row
  // clicks through to the record it describes. Free-text, not an FK —
  // matches the loose-coupling convention of the other log models
  // (Interaction.loggedBy, Activity.actor).
  link   String?

  createdAt DateTime @default(now())

  @@index([ts])
}

// ──────────────────────────────────────────────────────────────────────
// Task — dashboard "do" list
// ──────────────────────────────────────────────────────────────────────

model Task {
  id            String       @id @default(cuid())
  title         String
  // Nullable: an ingested task with no stated deadline shows "no date" instead of
  // a fake one (was stamped with the source date, so everything looked overdue).
  due           DateTime?
  priority      TaskPriority
  relatedTo     String?
  // Board column. `done` is kept in sync (done === status "done") so existing
  // dashboard widgets and toggleTaskDone keep working.
  status        TaskStatus   @default(todo)
  done          Boolean      @default(false)
  // Board categorisation — colour/tag. Defaults from scope; editable.
  category      WorkCategory @default(other)
  categoryLabel String?
  // Free-text context for the task — manual notes and/or suggested context.
  // No task is a bare button: this is the payload API agents will read (Phase 4+).
  context       String?

  // The owner IS the assignee. Nullable — a task can sit UNASSIGNED (drives the
  // milestone's orange "sub-task not assigned" state). assignedBy records who
  // handed it over (null = self-created / firm / unassigned).
  owner        Partner? @relation("TaskOwner", fields: [ownerId], references: [id])
  ownerId      String?
  assignedBy   Partner? @relation("TaskAssignedBy", fields: [assignedById], references: [id])
  assignedById String?

  // When set, the task has been moved to the board's Archive column. The
  // timestamp drives the 7-day auto-hide (mirrors Milestone.archivedAt).
  archivedAt    DateTime?

  // Scoping FKs (nullable — firm-wide tasks have neither).
  // Enables "what's open on Acme" queries without parsing relatedTo.
  client      Client?    @relation(fields: [clientId], references: [id])
  clientId    String?
  project     Project?   @relation(fields: [projectId], references: [id])
  projectId   String?
  // The deal this task hangs off, if any (pipeline task).
  deal        Deal?      @relation(fields: [dealId], references: [id])
  dealId      String?
  // The contact this task hangs off, if any.
  contact     Contact?   @relation(fields: [contactId], references: [id])
  contactId   String?
  // The deliverable this task hangs off, if any (deliverable card → add task).
  artifact    Artifact?  @relation(fields: [artifactId], references: [id])
  artifactId  String?
  // The milestone (epic) this task is a sub-task of, if any. SetNull so
  // deleting a milestone nulls its child tasks instead of failing on Restrict.
  milestone   Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  milestoneId String?

  // Reviewer — a partner asked to review this task's output (optional).
  reviewer   Partner? @relation("TaskReviewer", fields: [reviewerId], references: [id])
  reviewerId String?

  // Messages that reference this task render as inline task cards in chat.
  // One Task row, surfaced in three places (chat card, Tasks tab, feed).
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([projectId])
  @@index([dealId])
  @@index([contactId])
  @@index([artifactId])
  @@index([milestoneId])
  @@index([reviewerId])
  @@index([status])
}

// ──────────────────────────────────────────────────────────────────────
// FeatureRequest — the in-tool "Feature Requests & Fixes" board. Any partner
// files one (description + which part of the app it's about + a type) and any
// partner can move its status. No firm-money data → not managing-partner gated.
// ──────────────────────────────────────────────────────────────────────

model FeatureRequest {
  id          String               @id @default(cuid())
  title       String
  description String
  type        FeatureRequestType
  status      FeatureRequestStatus @default(open)

  // Which part of the app this is about. Stored as the area KEY + sub-tab LABEL
  // from lib/feature-area-taxonomy.ts (a TS constant, NOT a DB enum) so the nav
  // can change without a migration. areaTab "__app__" = whole app / cross-cutting;
  // areaSubTab is null when the chosen tab has no sub-tabs.
  areaTab    String
  areaSubTab String?

  // Who filed it (captured from the session — not a form field).
  createdBy   Partner @relation("FeatureRequestsCreated", fields: [createdById], references: [id])
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([areaTab])
  @@index([createdById])
  @@index([createdAt])
}

// ──────────────────────────────────────────────────────────────────────
// TeamUpdate — dashboard "know" feed
// ──────────────────────────────────────────────────────────────────────

model TeamUpdate {
  id      String        @id @default(cuid())
  ts      DateTime
  author  String
  cadence UpdateCadence
  body    String

  createdAt DateTime @default(now())

  @@index([ts])
}

// ──────────────────────────────────────────────────────────────────────
// NewsItem — industry news for the "know" feed
// ──────────────────────────────────────────────────────────────────────

model NewsItem {
  id       String   @id @default(cuid())
  ts       DateTime
  source   String
  industry Industry
  headline String
  why      String

  createdAt DateTime @default(now())

  @@index([ts])
}

// ──────────────────────────────────────────────────────────────────────
// Artifact — first-class deliverable tracking. Every AI-generated or
// partner-uploaded file gets a row. Powers Deliverables tabs + harvest.
// Persistence recipe in shiftai-ops/CLAUDE.md "Wire a Quick Action".
// ──────────────────────────────────────────────────────────────────────

// ──────────────────────────────────────────────────────────────────────
// Firm Knowledge — the firm's central brain. KnowledgeCategory is the MECE
// top-level taxonomy spine (Phase 1). Firm-wide Artifacts (null Client/
// Project/Deal scope) are filed into a category; a later phase adds a
// dedicated KnowledgeItem table for uploaded docs. One steward (Partner)
// owns each category and a review cadence drives the staleness badge.
// ──────────────────────────────────────────────────────────────────────

model KnowledgeCategory {
  id          String  @id @default(cuid())
  slug        String  @unique
  label       String
  description String?

  // Self-relation for optional sub-categories (max depth ~3-4 by convention).
  parentId String?
  parent   KnowledgeCategory?  @relation("KnowledgeCategoryTree", fields: [parentId], references: [id])
  children KnowledgeCategory[] @relation("KnowledgeCategoryTree")

  // One named owner per category (nullable until Phase 0 assigns stewards).
  stewardId String?
  steward   Partner? @relation("KnowledgeCategorySteward", fields: [stewardId], references: [id])

  // Freshness drumbeat: 0 = continuous, else days-until-stale (e.g. 90 / 365).
  reviewCadenceDays Int @default(90)
  sortOrder         Int @default(0)

  // Firm-wide artifacts filed into this category (Phase 1 reuses Artifact).
  artifacts Artifact[]

  // Tier-2 records filed into this category (Phase 3).
  knowledgeItems KnowledgeItem[]
  decisions      DecisionRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([stewardId])
}

// ──────────────────────────────────────────────────────────────────────
// MemoryBlock — Tier-1 recent memory. A fixed, curated set of small blocks
// (one row per MemoryBlockKey) that load into EVERY skill's context as a
// cached system block. `draftBody` is the work-in-progress; `approvedBody`
// is what skills actually read — so editing never leaks unreviewed content
// into AI context. Phase 2 is manual (partners write + approve); a later
// phase adds a weekly cron that regenerates drafts from the week's activity.
// ──────────────────────────────────────────────────────────────────────

model MemoryBlock {
  id          String         @id @default(cuid())
  key         MemoryBlockKey @unique
  label       String
  description String // one line: what it holds / when a skill should read it

  // draftBody = editable; approvedBody = what loads into skill context (the
  // only field a skill ever sees). They diverge while edits await approval.
  draftBody    String  @default("")
  approvedBody String?

  // As-of date shown in the block header so a skill knows how fresh it is.
  asOf DateTime?

  // firm_wide loads for everyone; managing_partner blocks are filtered out at
  // retrieval time for non-MP sessions (no MP blocks in v1, but the gate holds).
  sensitivity KnowledgeSensitivity @default(firm_wide)

  approvedById String?
  approvedBy   Partner?  @relation("MemoryBlockApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  updatedBy    String? // free-text actor label ("Jason Lotoski" / "AGENT · CLAUDE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([approvedById])
}

model Artifact {
  id                 String               @id @default(cuid())
  type               ArtifactType
  title              String
  driveUrl           String
  fileName           String?
  // Free-text actor — partner name OR agent label ("AGENT · CLAUDE").
  createdBy          String
  generatedFromSkill String?
  reviewStatus       ArtifactReviewStatus @default(draft)

  // Scope FKs — exactly one expected at write time, all nullable so
  // a single model serves Client/Project/Deal scopes without a join table.
  client    Client?  @relation(fields: [clientId], references: [id])
  clientId  String?
  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?
  deal      Deal?    @relation(fields: [dealId], references: [id])
  dealId    String?

  // Tasks scoped to this deliverable (deliverable card → add task → assign).
  tasks Task[]

  // Versioning: a "replace / new version" upload creates a NEW row pointing at the
  // one it supersedes, so a document is ONE record with a history instead of N
  // look-alike rows. A "head" = an artifact with no live row pointing at it.
  supersedesId String?
  supersedes   Artifact?  @relation("ArtifactVersions", fields: [supersedesId], references: [id])
  supersededBy Artifact[] @relation("ArtifactVersions")

  // ── Firm Knowledge governance (Phase 1, additive + nullable) ──────────
  // Lets a firm-wide artifact (null client/project/deal) be filed into the
  // knowledge taxonomy and carry stewardship + freshness metadata. Ordinary
  // client-scoped artifacts default to firm_wide / null and are unaffected.
  // A retrieval-time sensitivity filter (later phase) reads `sensitivity`
  // before any chunk enters an AI skill's context.
  sensitivity         KnowledgeSensitivity @default(firm_wide)
  knowledgeCategoryId String?
  knowledgeCategory   KnowledgeCategory?   @relation(fields: [knowledgeCategoryId], references: [id])
  ownerId             String?
  owner               Partner?             @relation("ArtifactOwner", fields: [ownerId], references: [id])
  lastVerifiedAt      DateTime?
  confidence          KnowledgeConfidence?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, createdAt])
  @@index([projectId, createdAt])
  @@index([dealId, createdAt])
  @@index([supersedesId])
  @@index([knowledgeCategoryId])
  @@index([ownerId])
}

// ──────────────────────────────────────────────────────────────────────
// KnowledgeItem — Tier-2 historical knowledge (Phase 3). The append-only,
// retrieved-on-demand system of record: uploaded docs (+ extracted text),
// captured pages, transcripts. NOT auto-injected into skill context — a skill
// calls fetchHistoricalKnowledge() only when a question needs history beyond
// the recent-memory window. Separate table from Artifact because Artifact's
// driveUrl is REQUIRED and it lacks storage/parse/as-of fields.
//
// Versioning mirrors Artifact: a "replace" writes a NEW row pointing at the one
// it supersedes (one logical doc = one chain). `fts` is a Postgres generated
// tsvector column (created in the prepared migration, not by Prisma) used for
// keyword retrieval; it is Unsupported() here so the client omits it and search
// runs via $queryRaw on the singleton client.
// ──────────────────────────────────────────────────────────────────────

model KnowledgeItem {
  id       String          @id @default(cuid())
  title    String
  source   KnowledgeSource @default(uploaded)

  // Curated one-paragraph summary (what a skill reads first); extractedText is
  // the full parsed body (FTS + deep context). Both nullable until parsed.
  summary       String?
  extractedText String?

  // Stored blob (Supabase Storage key in the private firm-knowledge bucket) +
  // original file metadata. storagePath is null for inline-text sources.
  storagePath String?
  fileName    String?
  mimeType    String?
  byteSize    Int?
  // SHA-256 of the extracted text — exact-dedup short-circuit on re-upload.
  contentHash String?

  // Click-out to the same doc in Drive, when one exists (parallel to Artifact).
  driveUrl String?

  // Async parse lifecycle (the knowledge-parse cron owns the transitions).
  parseStatus KnowledgeParseStatus @default(pending)
  parseError  String?
  parsedAt    DateTime?

  // Taxonomy + governance (mirrors the Artifact Phase-1 governance columns).
  category            KnowledgeCategory?   @relation(fields: [knowledgeCategoryId], references: [id])
  knowledgeCategoryId String?
  reviewStatus        ArtifactReviewStatus @default(draft)
  sensitivity         KnowledgeSensitivity @default(firm_wide)
  owner               Partner?             @relation("KnowledgeItemOwner", fields: [ownerId], references: [id])
  ownerId             String?
  confidence          KnowledgeConfidence?
  lastVerifiedAt      DateTime?

  // As-of stamping — when the knowledge was true / observed (distinct from the
  // row's createdAt). Lets a skill reason about recency, not just insertion.
  validFrom  DateTime?
  observedAt DateTime?

  // Provenance.
  generatedFromSkill String?
  createdBy          String // partner name or "AGENT · CLAUDE"

  // Optional scope FKs — a knowledge item can be firm-wide (all null) or tied to
  // a client/project/deal (lifted IP, a captured deliverable). All nullable.
  client    Client?  @relation(fields: [clientId], references: [id])
  clientId  String?
  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?
  deal      Deal?    @relation(fields: [dealId], references: [id])
  dealId    String?

  // Versioning chain (reuse the Artifact pattern).
  supersedesId String?
  supersedes   KnowledgeItem?  @relation("KnowledgeItemVersions", fields: [supersedesId], references: [id])
  supersededBy KnowledgeItem[] @relation("KnowledgeItemVersions")

  tags KnowledgeItemTag[]

  // Postgres generated tsvector (title + summary + extractedText). Created in
  // the prepared migration; Prisma never writes it. GIN-indexed for FTS.
  fts Unsupported("tsvector")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([knowledgeCategoryId, reviewStatus])
  @@index([ownerId])
  @@index([contentHash])
  @@index([supersedesId])
  @@index([parseStatus])
  @@index([clientId])
  @@index([projectId])
  @@index([dealId])
  @@index([fts], type: Gin)
}

// ──────────────────────────────────────────────────────────────────────
// DecisionRecord — ADR-style decision log (Phase 3). The single highest-leverage
// new record type for a partner firm: what was decided, the options weighed, and
// the consequences, stamped + attributable. A meeting transcript can distill into
// one (sourceInteraction). Append-only with the same supersede-don't-overwrite
// versioning as KnowledgeItem.
// ──────────────────────────────────────────────────────────────────────

model DecisionRecord {
  id    String @id @default(cuid())
  title String

  // The ADR body. context = the situation; optionsConsidered = what was weighed;
  // decision = what was chosen; consequences = what it commits the firm to.
  context          String?
  optionsConsidered String?
  decision         String
  consequences     String?

  decidedAt   DateTime
  decidedBy   Partner? @relation("DecisionDecidedBy", fields: [decidedById], references: [id])
  decidedById String?
  // Free-text actor fallback when the decider is not a Partner row (or for an
  // agent-distilled draft). Parallel to Interaction.loggedBy.
  decidedByLabel String?

  // The meeting / email this decision was distilled from, if any.
  sourceInteraction   Interaction? @relation("DecisionSourceInteraction", fields: [sourceInteractionId], references: [id])
  sourceInteractionId String?

  category            KnowledgeCategory?   @relation(fields: [knowledgeCategoryId], references: [id])
  knowledgeCategoryId String?
  reviewStatus        ArtifactReviewStatus @default(draft)
  sensitivity         KnowledgeSensitivity @default(firm_wide)
  validFrom           DateTime?

  generatedFromSkill String?
  createdBy          String

  supersedesId String?
  supersedes   DecisionRecord?  @relation("DecisionVersions", fields: [supersedesId], references: [id])
  supersededBy DecisionRecord[] @relation("DecisionVersions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([knowledgeCategoryId, reviewStatus])
  @@index([decidedById])
  @@index([sourceInteractionId])
  @@index([supersedesId])
  @@index([decidedAt])
}

// ──────────────────────────────────────────────────────────────────────
// KnowledgeTag + KnowledgeItemTag — controlled-vocabulary facet layer. A
// steward-maintained term list (NOT free text — avoids the tag-rot the tool's
// free-text enrichment would reproduce). Contributors pick existing tags; only
// a tag steward mints new ones.
// ──────────────────────────────────────────────────────────────────────

model KnowledgeTag {
  id          String  @id @default(cuid())
  slug        String  @unique
  label       String
  description String?

  steward   Partner? @relation("KnowledgeTagSteward", fields: [stewardId], references: [id])
  stewardId String?

  items KnowledgeItemTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stewardId])
}

model KnowledgeItemTag {
  knowledgeItem   KnowledgeItem @relation(fields: [knowledgeItemId], references: [id], onDelete: Cascade)
  knowledgeItemId String
  tag             KnowledgeTag  @relation(fields: [knowledgeTagId], references: [id], onDelete: Cascade)
  knowledgeTagId  String

  @@id([knowledgeItemId, knowledgeTagId])
  @@index([knowledgeTagId])
}

// ──────────────────────────────────────────────────────────────────────
// ActionDraft — the editable step-1 output of a Quick Action, saved before
// it's run into a finished deliverable. `skill` is the generatedFromSkill
// value; `content` is the editable JSON (e.g. a reviewable brief). Scope FKs
// are nullable so one model serves Client/Project/Deal/Contact scopes — the
// loose-coupling convention the rest of the schema uses (Artifact, Task).
// ──────────────────────────────────────────────────────────────────────

model ActionDraft {
  id        String @id @default(cuid())
  skill     String // the generatedFromSkill value
  content   Json // the editable step-1 output
  status    String @default("draft")
  createdBy String // partner name or "AGENT · CLAUDE"

  // Scope FKs — exactly one expected at write time, all nullable.
  client    Client?  @relation(fields: [clientId], references: [id])
  clientId  String?
  deal      Deal?    @relation(fields: [dealId], references: [id])
  dealId    String?
  contact   Contact? @relation(fields: [contactId], references: [id])
  contactId String?
  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([dealId])
  @@index([contactId])
  @@index([projectId])
  @@index([skill])
}

// ──────────────────────────────────────────────────────────────────────
// AuditLog — every write logged with actor + timestamp.
// Foundation for the AI activity audit acquirers will want (Phase 2C, §11).
// Append-only by convention (no updatedAt; no UI delete path).
// ──────────────────────────────────────────────────────────────────────

// ──────────────────────────────────────────────────────────────────────
// AgentPlan — Firm Agents tab (B5). A collaboration surface, NOT a deploy:
// partners draft what an agent SHOULD do (goal + key tasks) before any
// SKILL.md / scheduled run exists. Simple CRUD. The "live agents" half of
// the tab reads the actual SKILL.md files off disk (no model needed).
// ──────────────────────────────────────────────────────────────────────

model AgentPlan {
  id       String          @id @default(cuid())
  name     String
  goal     String
  keyTasks String[]
  notes    String?
  status   AgentPlanStatus @default(idea)
  kind     AgentPlanKind   @default(agent)

  createdBy   Partner @relation("AgentPlanCreatedBy", fields: [createdById], references: [id])
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([kind])
}

// ──────────────────────────────────────────────────────────────────────
// Lead Agent — Phase A: Targeting.
// A TargetSegment is an editable ideal-customer spec the Lead Agent hunts
// against. `industries` are FREE-FORM string tags (NOT the 5-value Industry
// enum, which stays untouched). Revenue/employee bounds are whole numbers
// (revenue in whole CAD, no cents). `searchSpec` is an opaque agent-config
// blob (Json?) the search layer fills in later. Self-contained — no Partner
// relation in Phase A.
// ──────────────────────────────────────────────────────────────────────

model TargetSegment {
  id               String   @id @default(cuid())
  name             String
  description      String
  active           Boolean  @default(true)
  priority         Int      @default(0)
  industries       String[]
  revenueMin       Int?
  revenueMax       Int?
  employeeMin      Int?
  employeeMax      Int?
  geographies      String[]
  buyingSignals    String[]
  disqualifiers    String[]
  searchSpec       Json?
  // personas: Json array of { department: string, seniority: string }
  personas         Json?
  // anchors: Json array of { name: string, domain?: string }
  anchors          Json?
  // priorityLocation: the starred geography (must be one of geographies)
  priorityLocation String?

  // revealAtDiscovery: per-segment Apollo email-reveal policy at discovery time.
  // "primary" (default) reveals only the primary contact's email per company
  // (1 credit); "all" reveals every found contact's email (1 credit each).
  revealAtDiscovery String? @default("primary")

  // Set when a partner runs the Segment Optimizer (D39). A LeadRun newer than
  // this (or runs existing while this is null) means Claude has fresh tuning
  // suggestions for the segment — drives the "Claude has suggestions" nudge.
  lastOptimizedAt DateTime?

  // Phase B back-relations.
  prospectLeads ProspectLead[]
  leadRuns      LeadRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, priority])
}

// ──────────────────────────────────────────────────────────────────────
// ProspectLead (Phase B) — a discovered prospect awaiting partner review.
// Discovery (Phase C) writes these; the AI Found Leads surface reads them.
// ──────────────────────────────────────────────────────────────────────

model ProspectLead {
  id               String   @id @default(cuid())
  companyName      String
  // Normalized bare domain (lowercase, no scheme/www). UNIQUE so a company
  // can't be discovered twice across runs (D15 dedup key).
  domain           String   @unique
  website          String?
  industryTags     String[]
  revenueEstimate  Int? // whole CAD
  employeeEstimate Int?
  headquarters     String?

  // ── Company picture (mirrors the Deal profile; filled by enrich) ──
  linkedinUrl     String?
  instagramUrl    String?
  companySize     String?
  founded         String?
  ownership       String?
  description     String?
  subIndustry     String?
  currentSystems  String[] @default([])
  painPoints      String[] @default([])
  companyKeyFacts String[] @default([])

  // ── Positioning ("how we'd sell to them"; lead-positioning skill) ──
  fitSummary  String? // how this company maps to who Shift AI is / what we do
  likelyNeeds String[] @default([]) // grounded "X because Y" needs
  salesAngle  String? // how to open and position the pitch

  // Stamped when the combined enrich pass last built the picture.
  enrichedAt DateTime?

  // Matched segment (nullable — a lead can be unsegmented).
  segment   TargetSegment? @relation(fields: [segmentId], references: [id])
  segmentId String?

  score        Int // 1–10 fit score
  rationale    String // one-paragraph why-it-fits
  disqualified Boolean            @default(false)
  status       ProspectLeadStatus @default(pending)

  // people: Json array of { name, title, email?, linkedin?, source? }
  people  Json     @default("[]")
  // foundBy: source connectors that surfaced it, e.g. ["firecrawl","apollo"]
  foundBy String[]
  // sources: raw per-source payloads (opaque), e.g. { firecrawl: {...} }
  sources Json?

  createdBy          String  @default("AGENT · CLAUDE")
  generatedFromSkill String?

  // Where this lead came from. `discovery` (default) keeps every existing row
  // on the AI Found Leads surface; `imported` rows show in the new Pipeline
  // "Promoted Leads" sub-tab. The two sub-tabs filter on this.
  origin     ProspectLeadOrigin @default(discovery)
  // For imported leads: the partner who promoted it (provenance only — the lead
  // itself is firm-wide and visible to everyone, like a discovery lead).
  promotedBy String?

  // Set on Add-to-funnel; loose strings (match loose-coupling convention).
  convertedContactId String?
  convertedDealId    String?

  reviewedBy String?
  reviewedAt DateTime?

  // Claim/assign — the partner working this lead. claimedById is a loose
  // partner-id string (no FK — matches promotedBy/reviewedBy convention);
  // claimedBy is the display label. Null = unclaimed.
  claimedById String?
  claimedBy   String?
  claimedAt   DateTime?

  // Cold-outreach draft (Phase B.1). The draft lives on the lead itself — there
  // is no Artifact scope for a ProspectLead. outreachPersonIndex points into the
  // people Json array; outreachSentAt is set when the partner marks it sent
  // (status → contacted).
  outreachSubject     String?
  outreachDraft       String?
  outreachPersonIndex Int?
  outreachSentAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, score])
  @@index([segmentId])
  // The new "Promoted Leads" sub-tab filters origin=imported; AI Found Leads
  // filters origin=discovery. Index both reads.
  @@index([origin, status, score])
}

// ──────────────────────────────────────────────────────────────────────
// LeadRun (Phase B) — one discovery pass over a segment (provenance/metrics).
// ──────────────────────────────────────────────────────────────────────

model LeadRun {
  id             String         @id @default(cuid())
  segment        TargetSegment? @relation(fields: [segmentId], references: [id])
  segmentId      String?
  status         LeadRunStatus  @default(running)
  evaluatedCount Int            @default(0)
  foundCount     Int            @default(0)
  ghostCount     Int            @default(0)
  createdBy      String         @default("AGENT · CLAUDE")
  startedAt      DateTime       @default(now())
  finishedAt     DateTime?

  @@index([segmentId, startedAt])
}

// ──────────────────────────────────────────────────────────────────────
// Import Contacts — PRIVATE per-partner staging. A partner uploads a CSV
// (LinkedIn / Google Contacts export); rows land here, get scanned for fit,
// and the qualified ones are PROMOTED into firm-wide ProspectLeads.
//
// PRIVACY INVARIANT (new in this codebase — nothing else filters by partner):
// every read/write of ImportBatch / ImportedContact / ScanRun MUST be scoped
// to session.user.partnerId. partnerLeadId is denormalized onto every row so
// a read can filter without a join. See lib/import-auth.ts requirePartner().
// ──────────────────────────────────────────────────────────────────────

// One CSV upload.
model ImportBatch {
  id String @id @default(cuid())

  // PRIVATE scope — the importing partner.
  partnerLead   Partner @relation("PartnerImportBatch", fields: [partnerLeadId], references: [id])
  partnerLeadId String

  filename      String
  source        String // "linkedin" | "google" | "other" — detected at upload
  // The header→field mapping used for this file (provenance + re-import).
  columnMapping Json?

  totalRows     Int @default(0)
  importedRows  Int @default(0) // rows actually written (post-dedupe)
  duplicateRows Int @default(0) // skipped as dupes within this partner's space
  needsIdCount  Int @default(0) // rows flagged needs_identification

  createdBy String // partner display label

  contacts ImportedContact[]
  scanRuns ScanRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partnerLeadId, createdAt])
}

// One imported person.
model ImportedContact {
  id String @id @default(cuid())

  // PRIVATE scope (denormalized for filter-without-join).
  partnerLead   Partner @relation("PartnerImportedContact", fields: [partnerLeadId], references: [id])
  partnerLeadId String

  batch   ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  batchId String

  // ── Identity (cleaned) ──
  name     String
  title    String?
  company  String?
  email    String?
  phone    String?
  linkedin String?
  // Normalized bare domain (lowercase, no scheme/www) from email or a website
  // column. May be "" / null when unknown. NOT unique (private; may be empty).
  domain   String?

  // The original CSV row as parsed (provenance — lets us re-derive on remap).
  raw Json

  // ── Completeness / dedupe ──
  completeness ImportContactCompleteness @default(complete)
  // Stable per-partner dedupe key: normalized email, else lower(name)|lower(company).
  dedupeKey    String

  // ── Scan results (written by the scan) ──
  scanStatus       ImportScanStatus @default(pending)
  scanScore        Int? // 1–10
  leadType         ImportLeadType?
  matchedSegmentId String? // which TargetSegment the company fit (nullable)
  scanRationale    String?
  scannedAt        DateTime?

  // ── Promotion ──
  promotion              ImportContactPromotion @default(none)
  promotedProspectLeadId String? // loose string (match loose-coupling convention)
  promotedAt             DateTime?

  scanResults ScanResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // DB-level per-partner dedupe (belt-and-suspenders on top of the app check).
  @@unique([partnerLeadId, dedupeKey])
  // Hot read path: this partner's rows, newest/highest score.
  @@index([partnerLeadId, scanStatus, scanScore])
  @@index([batchId])
  @@index([matchedSegmentId])
}

// One scan pass over a partner's imported set.
model ScanRun {
  id String @id @default(cuid())

  partnerLead   Partner @relation("PartnerScanRun", fields: [partnerLeadId], references: [id])
  partnerLeadId String

  // Scoped to one batch, or null = all of this partner's unscanned rows.
  batch   ImportBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  batchId String?

  // Partner-facing report title/tag (e.g. "Construction owners — Jun 3").
  title  String        @default("Scan")
  status ScanRunStatus @default(pending)

  // The criteria this scan rated against (the saved scan settings, seeded from a
  // segment then edited). Shape: { industries[], employeeMin?, employeeMax?,
  // revenueMin?, revenueMax?, geographies[], keywords[], seededFromSegmentId?,
  // seededFromName? }. Snapshotted so each report records what it looked for.
  criteria Json?

  // Anthropic Message Batches API id (the bulk async path). Null on the inline path.
  batchApiId String?

  // When the current ingest attempt claimed this run (submitted→scoring, or a
  // re-claim of a dead attempt). Bulk ingest takes seconds, so a claim older
  // than INGEST_CLAIM_TTL_MS (5 min, lib/contact-scan.ts) means the serverless
  // invocation died mid-write and the run may be re-claimed and resumed.
  ingestClaimedAt DateTime?

  // The imported-contact ids in this scan, in request order. Each batch result
  // carries a global `index` that maps back to contactIds[index] — so ingest
  // (a LATER request than submit) never depends on unstable row ordering.
  contactIds String[]

  // Counts — drive the progress UI (mirrors LeadRun's count fields).
  totalCount   Int @default(0) // rows in scope (excludes needs_identification)
  scoredCount  Int @default(0)
  skippedCount Int @default(0)
  errorCount   Int @default(0)

  // Snapshot of the active TargetSegment ids used as the "fitting company"
  // definition for this run.
  segmentScope String[]

  createdBy  String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  results ScanResult[]

  @@index([partnerLeadId, startedAt])
}

// One scan's ranking of one imported contact — the "result column" per scan.
// A scan (ScanRun) produces one ScanResult per scanned contact, linking back to
// the SAME master ImportedContact (no contact duplication). Deleting a scan
// report cascades its results; deleting a contact cascades its results too.
model ScanResult {
  id String @id @default(cuid())

  scanRun   ScanRun @relation(fields: [scanRunId], references: [id], onDelete: Cascade)
  scanRunId String

  importedContact   ImportedContact @relation(fields: [importedContactId], references: [id], onDelete: Cascade)
  importedContactId String

  // Denormalized partner scope (the report reads are scoped through the run, but
  // this keeps every ScanResult query filterable without a join).
  partnerLeadId String

  score     Int // 1–10
  leadType  ImportLeadType
  rationale String?

  createdAt DateTime @default(now())

  @@unique([scanRunId, importedContactId])
  @@index([scanRunId, score])
  @@index([importedContactId])
}

// ──────────────────────────────────────────────────────────────────────
// Messaging (B4) — the firm timeline's two interactive lanes (channels + DMs).
// The third lane is the existing Activity feed. Real-time is short-interval
// polling (getMessagesSince) — no new infra. A system Message (authorId null)
// with a taskId set renders as an inline task card.
// ──────────────────────────────────────────────────────────────────────

model Channel {
  id        String          @id @default(cuid())
  kind      ChannelKind
  name      String? // null for DMs (label derived from the members)
  members   ChannelMember[]
  messages  Message[]
  createdAt DateTime        @default(now())

  @@index([kind])
}

model ChannelMember {
  channel    Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId  String
  partner    Partner   @relation(fields: [partnerId], references: [id])
  partnerId  String
  lastReadAt DateTime? // drives unread badges

  @@id([channelId, partnerId])
  @@index([partnerId])
}

model Message {
  id        String      @id @default(cuid())
  channel   Channel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId String
  // Partner FK; null = system message (e.g. a task-assignment card).
  author    Partner?    @relation(fields: [authorId], references: [id])
  authorId  String?
  body      String
  // Notification type — 'chat' for ordinary messages, or a typed system note
  // (drives color + icon + sort in the per-partner system chat).
  kind      MessageKind @default(chat)
  // If set, render this message as an inline task card.
  task      Task?       @relation(fields: [taskId], references: [id])
  taskId    String?
  // Optional deep-link for a system note (e.g. "/ingest", "/projects/<id>") —
  // makes a typed notification click through to the thing it's about.
  link      String?
  createdAt DateTime    @default(now())

  @@index([channelId, createdAt])
}

// ──────────────────────────────────────────────────────────────────────
// IngestProposal — meeting ingest review queue (Phase 4b). A recorded/pasted
// call is EXTRACTED into a structured proposal (summary, key points,
// enrichment, action items, stage signal) and held here as PENDING until a
// partner approves — propose-never-auto-write. On approval the proposal is
// persisted through the canonical recipe (Artifact + Interaction + Tasks +
// append-only enrichment + AuditLog), tagged "AGENT · CLAUDE".
//
// Matched entity ids are loose strings (no FK back-relations), matching the
// codebase's loose-coupling convention (Activity.link, Interaction.loggedBy).
// externalId is the Fireflies meeting id — UNIQUE for webhook idempotency.
// ──────────────────────────────────────────────────────────────────────

model IngestProposal {
  id          String       @id @default(cuid())
  source      IngestSource @default(paste)
  externalId  String?      @unique
  title       String
  meetingDate DateTime
  transcript  String
  proposal    Json
  status      IngestStatus @default(pending)
  // Unified ingest (v2): the kind of thing ingested — interaction | meeting |
  // email | document. Nullable so legacy (v1) proposals stay valid; the value
  // is also carried in `proposal` JSON. Used for list filtering / labels.
  ingestType  String?

  matchedContactId String?
  matchedClientId  String?
  matchedDealId    String?
  matchedProjectId String?

  // Gmail thread id — groups a thread's messages so the poll collapses replies into
  // ONE growing proposal (append + re-extract) instead of one proposal per message.
  // externalId stays the per-MESSAGE idempotency key; appended message ids live in
  // the proposal JSON (messageIds[]). Null for paste/meeting (no thread).
  threadId String?

  createdBy  String // partner label or "AGENT · CLAUDE"
  reviewedBy String?
  reviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([threadId])
  @@index([source, status])
}

// Per-partner Gmail OAuth connection (label-based email ingest). One row per
// partner who has connected. refreshToken is AES-256-GCM encrypted at rest
// (lib/crypto.ts) — never stored in the clear. See docs/gmail-integration-plan.md.
model PartnerGmailAuth {
  id           String   @id @default(cuid())
  partnerId    String   @unique
  email        String // the Google account that granted access
  refreshToken String // encrypted
  scope        String
  connectedAt  DateTime @default(now())
  lastError    String? // last token-refresh failure → UI prompts a reconnect
  partner      Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
}

// Incremental ingest cursor — one row per (partner, source). For Gmail the
// cursor is the mailbox historyId we last processed, so each poll only reads
// what's new. Unique on (partnerId, source).
model IngestSyncState {
  id        String       @id @default(cuid())
  partnerId String
  source    IngestSource
  cursor    String? // Gmail historyId (null until first successful poll)
  updatedAt DateTime     @updatedAt
  partner   Partner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([partnerId, source])
}

// ──────────────────────────────────────────────────────────────────────
// RateTier — the firm's standard rate card (Phase 1). One row per billing
// tier. `billRateCents` is what the client is charged per hour; `payRateCents`
// is the person's take-home per hour. These are the DEFAULTS that seed each
// ProjectEconomicsLine / EstimateLine; per-line rates stay overridable. Rates
// step up only by partner vote — editing here is an explicit rate-card change.
// "Developer" is NOT a tier: a developer line is slotted at an existing tier's
// rates, so only the four real tiers (mp/senior/intermediate/junior) live here.
// ──────────────────────────────────────────────────────────────────────

model RateTier {
  id            String  @id @default(cuid())
  key           String  @unique // "mp" | "senior" | "intermediate" | "junior"
  name          String
  billRateCents Int
  payRateCents  Int
  sortOrder     Int     @default(0)
  active        Boolean @default(true)

  economicsLines ProjectEconomicsLine[]
  estimateLines  EstimateLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────────
// ProjectDirectCost — pass-through costs (travel, client SaaS, third-party
// tools). Billed to the client AT COST: they add to the client price but carry
// NO origination, NO firm-pool split, NO margin. Kept separate from
// ProjectEconomicsLine because direct costs are flat amounts, not hours×rate.
// `amount` is whole CAD (matches Invoice/Installment).
// ──────────────────────────────────────────────────────────────────────

model ProjectDirectCost {
  id        String  @id @default(cuid())
  label     String
  amount    Int // whole CAD, at cost
  notes     String?
  sortOrder Int     @default(0)

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, sortOrder])
}

// ──────────────────────────────────────────────────────────────────────
// Origination — who sourced a contract and their share of the 10% origination
// slot (Phase 2). 1–2 rows per project (shared origination), or zero (brand /
// website / non-partner referral → 0% to anyone, the slot rolls to firm pool).
// `sharePct` rows for a project sum to 100. Paid on the FIRST contract per
// client only (Project.isFirstContract); logged before SOW signature.
// ──────────────────────────────────────────────────────────────────────

model Origination {
  id       String  @id @default(cuid())
  sharePct Decimal @db.Decimal(5, 2) // share of the origination pool; rows sum to 100
  notes    String?

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  partner   Partner @relation(fields: [partnerId], references: [id])
  partnerId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, partnerId])
  @@index([projectId])
}

// ──────────────────────────────────────────────────────────────────────
// Deal-source commission + On-going Service Contracts (2026-06-22)
//
// A SEPARATE firm-money system from Origination above. A deal can carry 1-2
// commission payees (a partner OR an external referrer), each earning 1-10% of a
// chosen base (the build value, or the total 6/12-month value). At convert the
// deal commissions snapshot onto the build project (ProjectSourceCommission =
// the one-time build slice) and — for a subscription with a recurring base —
// onto a dedicated ServiceContract that begins on a FUTURE date, with a per-month
// accrual ledger. The ongoing contract is NOT a Project, so /financials never
// double-counts MRR as one-time budgetFee. Commission is never deducted from
// labour revenue and never enters the 10/15/75 allocateLaborRevenue split.
// CHECK constraints (payee XOR, pct 1-10) live in the migration SQL — Prisma
// can't author them — and are re-enforced in the server actions.
// ──────────────────────────────────────────────────────────────────────

model DealSourceCommission {
  id           String         @id @default(cuid())
  pct          Decimal        @db.Decimal(5, 2) // 1.00–10.00 per payee (not a pool share)
  base         CommissionBase @default(deal_value)
  externalName String? // set when partnerId is null (external referrer)
  notes        String?

  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId    String
  partner   Partner? @relation("PartnerDealCommission", fields: [partnerId], references: [id], onDelete: SetNull)
  partnerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
}

model ServiceContract {
  id         String                @id @default(cuid())
  name       String
  status     ServiceContractStatus @default(pending_start)
  monthlyFee Int // whole CAD; CANONICAL monthly figure (the contract has no budgetFee)
  termMonths Int                   @default(12)
  startDate  DateTime // FUTURE at create — seeded to the build project's targetEndDate
  endDate    DateTime?
  notes      String?

  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String  @unique // 1:1 with the build project
  client        Client  @relation(fields: [clientId], references: [id])
  clientId      String
  partnerLead   Partner @relation("PartnerServiceContractLead", fields: [partnerLeadId], references: [id])
  partnerLeadId String

  commissions OngoingContractCommission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status])
}

model ProjectSourceCommission {
  id                     String         @id @default(cuid())
  pct                    Decimal        @db.Decimal(5, 2)
  base                   CommissionBase @default(deal_value)
  buildAmount            Int // = round(pct/100 * build budgetFee); the ONE-TIME build slice
  externalName           String?
  notes                  String?
  sourceDealCommissionId String? // provenance; null = direct project-level fallback

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  partner   Partner? @relation("PartnerProjectCommission", fields: [partnerId], references: [id], onDelete: SetNull)
  partnerId String?
  ongoing   OngoingContractCommission? // back-relation of the 1:1 link below

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([partnerId])
}

model OngoingContractCommission {
  id              String         @id @default(cuid())
  pct             Decimal        @db.Decimal(5, 2)
  base            CommissionBase
  coveredMonths   Int // 6 or 12 (= N)
  projectedAmount Int // = round(pct/100 * monthlyFee * N)
  externalName    String?

  contract            ServiceContract          @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId          String
  projectCommission   ProjectSourceCommission? @relation(fields: [projectCommissionId], references: [id], onDelete: SetNull)
  projectCommissionId String?                  @unique // 1:1 link to the build twin (one logical line, both surfaces)
  partner             Partner?                 @relation("PartnerOngoingCommission", fields: [partnerId], references: [id], onDelete: SetNull)
  partnerId           String?

  accruals OngoingContractCommissionAccrual[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractId])
}

model OngoingContractCommissionAccrual {
  id          String                  @id @default(cuid())
  periodIndex Int // 0..N-1
  periodStart DateTime // = startDate + periodIndex months (the placeholder→payable flip date)
  amount      Int // = round(pct/100 * monthlyFee); remainder pushed to the LAST row
  status      CommissionAccrualStatus @default(projected)
  paidAt      DateTime?

  commission   OngoingContractCommission @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  commissionId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([commissionId, periodIndex])
  @@index([periodStart])
}

// ──────────────────────────────────────────────────────────────────────
// Estimate / EstimateLine — pre-proposal scoping (Phase 5). An Estimate hangs
// off a Deal: partners scope hours-by-tier before the proposal goes out. Lines
// default to the standard rate card and are overridable, mirroring
// ProjectEconomicsLine. Versionable: editing a `sent` estimate creates a new
// version and supersedes the old. On deal-won the `accepted` estimate's lines
// convert into the new project's economics lines.
// ──────────────────────────────────────────────────────────────────────

model Estimate {
  id         String         @id @default(cuid())
  version    Int            @default(1)
  status     EstimateStatus @default(draft)
  // Computed from lines (Σ hours×bill + direct costs), overridable.
  totalValue Int            @default(0)
  notes      String?

  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId String

  lines EstimateLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
}

model EstimateLine {
  id            String  @id @default(cuid())
  role          String
  hours         Decimal @db.Decimal(7, 2)
  payRateCents  Int
  billRateCents Int
  isExtra       Boolean @default(false)
  sortOrder     Int     @default(0)
  notes         String?

  estimate   Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  estimateId String

  rateTier   RateTier? @relation(fields: [rateTierId], references: [id])
  rateTierId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([estimateId, sortOrder])
}

model AuditLog {
  id         String   @id @default(cuid())
  ts         DateTime @default(now())
  actor      String // partner.id or "agent:<name>"
  actorLabel String
  action     String // e.g. "create.contact", "update.deal.stage"
  targetType String // e.g. "Contact", "Deal"
  targetId   String?
  changes    Json? // before/after diff
  ip         String?
  userAgent  String?

  @@index([ts])
  @@index([targetType, targetId])
}

// ──────────────────────────────────────────────────────────────────────
// ArchitectureNote — team notes left on a node of the architecture map
// (the /architecture tab). `nodeId` is the map node's slug; it is a loose
// string, NOT an FK, because the nodes live in code
// (components/architecture-map/model), not the DB — matching the codebase's
// loose-coupling convention (Activity.link, matched*Id). Every note is
// authored by a signed-in partner; any partner can delete any note.
// ──────────────────────────────────────────────────────────────────────
model ArchitectureNote {
  id        String   @id @default(cuid())
  nodeId    String
  body      String
  author    Partner  @relation(fields: [authorId], references: [id])
  authorId  String
  createdAt DateTime @default(now())

  @@index([nodeId, createdAt])
}

// Operational telemetry — every Claude call, cron run, ingest, integration
// check, and MCP tool call writes one row (success AND failure) so the Settings
// "System status" tab can show health, latency, token usage, and recent
// failures. Append-only log; pruned to ~30 days (pruneOpsEvents in lib/ops.ts).
// Written via the fire-and-forget logOps() helper — telemetry must never break
// the path it observes. Sibling of AuditLog (mutations) / Activity (human feed).
enum OpsKind {
  claude
  cron
  ingest
  integration
  mcp
}

enum OpsStatus {
  ok
  error
}

model OpsEvent {
  id         String    @id @default(cuid())
  ts         DateTime  @default(now())
  kind       OpsKind
  // Sub-type: claude→skill name; cron→"gmail-poll"|"fireflies-poll";
  // integration→"gmail"|"drive"; mcp→tool name; ingest→"fireflies"|"gmail".
  name       String
  status     OpsStatus
  actor      String // "AGENT · CLAUDE" | "AGENT · MCP" | "system" | partner name
  actorLabel String
  detail     String?
  error      String? // truncated ~500 chars; null on ok
  durationMs Int?

  inputTokens      Int?
  outputTokens     Int?
  cacheReadTokens  Int?
  cacheWriteTokens Int?
  model            String?

  clientId String? // loose scope link, no FK (matches Activity/AuditLog convention)
  meta     Json? // { skipped, created, deduped, partners, webSearch, … }

  @@index([ts])
  @@index([kind, ts])
  @@index([kind, status, ts])
}

// ──────────────────────────────────────────────────────────────────────
// Prototype builder (Phase B) — the autonomous Agent SDK worker (worker/) writes
// one PrototypeRun per build and one PrototypeIteration per build⇄critique round.
// Scope FKs to Deal/Client are nullable (the loose-coupling convention Artifact
// uses) so a run can be anchored to whichever the kickoff knew about. Big blobs
// (HTML, screenshots) live in Supabase Storage; only their URLs are stored here —
// never blobs in Postgres. The worker writes these rows DIRECTLY via lib/prisma
// (it is plain Node, not Next — no server action / revalidatePath).
// ──────────────────────────────────────────────────────────────────────
enum PrototypeRunStatus {
  pending
  running
  refining
  done
  error
}

model PrototypeRun {
  id     String             @id @default(cuid())
  status PrototypeRunStatus @default(running)

  // What this run builds: "prototype" (the interactive HTML demo) or "deck" (the
  // proposal deck that renders the approved SOW + links the prototype). Plain
  // string, not an enum (loose-coupling convention) — default keeps every existing
  // row and the prototype path byte-identical. The worker branches on it for the
  // skill, gate rubric, file name, and artifact type. See _prepared-migrations/009.
  kind String @default("prototype")

  // True once the single partner-refine pass has been consumed (one per run).
  refineUsed Boolean @default(false)

  // What was built — the brief's client name + industry, denormalized so a run is
  // legible without the originating Deal/Client (which may be null for dev runs).
  clientName String
  industry   String?

  // The SDK session for this run (resume / audit). Null until the loop starts.
  sessionId String?
  model     String?

  // The approved brief this run was built from (snapshot; the run is self-contained).
  brief String?
  // The final Artifact written on success — lets Home's approve action find it.
  artifactId String?

  // Outcome rollup, filled when the loop finishes.
  rounds       Int     @default(0)
  finalScore   Int? // the last round's overall (0–100)
  finalHtmlUrl String? // Supabase Storage URL of the final prototype.html
  error        String? // truncated message when status = error

  createdBy String @default("AGENT · CLAUDE")

  // Loose scope links — exactly one expected at kickoff, both nullable.
  deal     Deal?   @relation(fields: [dealId], references: [id])
  dealId   String?
  client   Client? @relation(fields: [clientId], references: [id])
  clientId String?

  iterations PrototypeIteration[]

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  @@index([dealId, startedAt])
  @@index([clientId, startedAt])
  @@index([status, startedAt])
}

model PrototypeIteration {
  id    String       @id @default(cuid())
  run   PrototypeRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId String

  round         Int
  partnerComment String? // the partner's note that triggered this round (refine pass only; null on auto rounds)
  htmlUrl       String? // Supabase Storage URL of this round's HTML snapshot
  screenshotUrl String? // Supabase Storage URL of this round's screenshot
  critique      String? // the round's self-critique (gate summary + open issues)
  score         Int? // this round's overall (0–100)

  // The gate sub-scores for this round, kept for the run timeline / tuning.
  structure     Int?
  fidelity      Int?
  design        Int?
  interactivity Int?

  createdAt DateTime @default(now())

  @@index([runId, round])
}

// Durable Agent SDK session store — mirrors each run's transcript so a resume
// (the partner-refine pass) works across worker restarts. One row per transcript
// entry; idempotent on (projectKey, sessionId, uuid). See lib/agent-session-store.ts.
model AgentSessionEntry {
  id         BigInt   @id @default(autoincrement())
  projectKey String
  sessionId  String
  uuid       String?
  data       Json
  createdAt  DateTime @default(now())

  @@unique([projectKey, sessionId, uuid])
  @@index([projectKey, sessionId, id])
}

// ──────────────────────────────────────────────────────────────────────
// AP / AR + Expenses (firm financials). Money OUT splits into two ledgers:
//   Bill    — a vendor invoice we owe (AP); entered manually or ingested from email.
//   Expense — a team receipt or a recurring subscription (reimbursable / firm-paid).
// Money IN stays on Invoice (AR). Amounts are whole CAD ints — the Invoice
// convention (rates elsewhere are cents; invoices/bills/expenses are whole CAD).
// Brand-new enums → plain underscored identifiers, NO @map (no legacy data), so
// lib/types.ts mirrors them verbatim (sidesteps the EngagementStatus mapping gotcha).
// ──────────────────────────────────────────────────────────────────────

enum BillStatus {
  received
  approved
  paid
  void
}

enum BillSource {
  manual
  gmail_ingest
}

enum ExpenseKind {
  reimbursable
  firm_paid
  subscription
}

enum ExpenseStatus {
  draft
  submitted
  approved
  reimbursed
  paid
}

enum MileageUnit {
  km
  receipt
}

enum ExpenseCategory {
  travel_accommodation
  travel_flights
  travel_meals
  bd_events
  bd_meals
  bd_other
  fuel_mileage
  subscription_software
  subscription_phone
  subscription_office
  subscription_other
  office_supplies
  professional_fees
  other
}

model Bill {
  id          String           @id @default(cuid())
  vendor      String
  number      String? // vendor's invoice number (NOT unique — different vendors reuse)
  description String?
  amount      Int // subtotal, whole CAD (already converted if the source was USD)
  gstBps      Int              @default(0)
  total       Int              @default(0)
  currency    String           @default("CAD") // currency of `amount`/`total` — always CAD once stored
  // Foreign-currency source (e.g. a USD invoice): the original figure + the rate
  // used to convert to CAD. Null when the invoice was already CAD. amount/total
  // stay CAD so all AP/AR/forecast math is unchanged.
  origAmount   Int?
  origCurrency String?
  fxRate       Decimal?         @db.Decimal(10, 4)
  category    ExpenseCategory?
  issuedAt    DateTime?
  dueAt       DateTime?
  paidAt      DateTime?
  status      BillStatus       @default(received)
  source      BillSource       @default(manual)
  notes       String?

  // Optional pass-through cost tag — a vendor bill billable to a client/project.
  client    Client?  @relation(fields: [clientId], references: [id])
  clientId  String?
  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?

  // The stored PDF/image in Drive (00-Firm-Financials/<yr>/AP-Bills/...).
  driveFileId String?
  driveUrl    String?
  fileName    String?

  createdBy String // partner name or "AGENT · CLAUDE"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, dueAt])
  @@index([clientId])
}

model Expense {
  id          String          @id @default(cuid())
  kind        ExpenseKind     @default(reimbursable)
  category    ExpenseCategory
  vendor      String?
  description String?
  amount      Int // whole CAD (already converted if the source was USD)
  gstBps      Int             @default(0)
  total       Int             @default(0)
  currency    String          @default("CAD") // currency of `amount`/`total` — always CAD once stored
  // Foreign-currency source (e.g. a USD receipt): original figure + rate used.
  // Null when already CAD. amount/total stay CAD.
  origAmount   Int?
  origCurrency String?
  fxRate       Decimal?        @db.Decimal(10, 4)
  spentAt     DateTime
  status      ExpenseStatus   @default(submitted)

  // fuel_mileage only — $/km (CRA rate snapshot) or an actual fuel receipt.
  mileageUnit      MileageUnit?
  mileageKm        Decimal?     @db.Decimal(7, 1)
  mileageRateCents Int? // CRA rate at entry (2026: 73¢ first 5,000 km, 67¢ after)

  // reimbursable only — who fronted it (a partner OR a non-partner
  // employee/contractor on the Consultant roster; exactly one is set), and when
  // we paid them back.
  paidBy            Partner?    @relation(fields: [paidById], references: [id])
  paidById          String?
  paidByConsultant  Consultant? @relation(fields: [paidByConsultantId], references: [id])
  paidByConsultantId String?
  reimbursedAt      DateTime?

  // subscription only — recurring SaaS/phone/office + next renewal.
  recurring   Boolean   @default(false)
  renewalDate DateTime?

  // Optional billable tag (pass-through to a client/project).
  client    Client?  @relation(fields: [clientId], references: [id])
  clientId  String?
  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?

  // Receipt doc in Drive; needsPhoto when saved without one ("needs photo").
  needsPhoto  Boolean @default(false)
  driveFileId String?
  driveUrl    String?
  fileName    String?

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, spentAt])
  @@index([category])
  @@index([paidById])
  @@index([paidByConsultantId])
}
